# --- Файлы сборки (build) ---
# Исключаем папки, которые создаются при сборке (названия могут меняться от настроек Qt Creator)
build-*/
build/
*.pro.user
*.pro.user.*
*.cmake
CMakeFiles/
CMakeCache.txt
cmake_install.cmake
Makefile
Makefile.*

# --- Мета-объекты и сгенерированные файлы ---
# Qt генерирует эти файлы при компиляции
moc_*.cpp
moc_*.h
qrc_*.cpp
ui_*.h

# --- Объекты и библиотеки ---
*.o
*.obj
*.so
*.dylib
*.dll
*.a
*.lib
*.exe

# --- Ресурсы и временные файлы ---
# Если проект использует Qt Design Studio или сложные qml-ресурсы
.qmake.stash
.qmake.cache
qmlcache_loader.cpp
*.qmlc

# --- Системные файлы ---
.DS_Store
Thumbs.db
*.pro.user
*.pro.user.*
.qtcreator/
build/

